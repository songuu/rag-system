    {
      "id": "contextual-v2-off-rolls-back-and-active-uses-deadline-seam",
      "input": {
        "kind": "contextual-retrieval-v2",
        "documentText": "Alpha founded Beta.",
        "chunkText": "Alpha founded Beta.",
        "generatedContext": "contract context"
      },
      "expected": {
        "off": {
          "mode": "off",
          "status": "disabled",
          "denseText": "Alpha founded Beta.",
          "participatesInDenseIndex": false,
          "providerCallsAfterOff": 0
        },
        "active": {
          "mode": "active",
          "status": "contextualized",
          "generatedContext": "contract context",
          "denseText": "contract context\n\nAlpha founded Beta.",
          "participatesInDenseIndex": true,
          "generatedCharacters": 16,
          "providerCalls": 1,
          "receivedInternalSignal": true
        }
      }
    },
    {
      "id": "identifier-abstention-requires-lexical-proof",
      "input": {
        "kind": "abstention",
        "queryKind": "identifier",
        "evidence": [
          {
            "id": "dense-identifier-candidate",
            "tenantId": "contract-tenant",
            "corpusId": "contract-corpus",
            "documentId": "document-a",
            "documentVersion": "v1",
            "content": "A semantically similar but unproven identifier.",
            "trustLevel": "reviewed",
            "laneId": "dense-main",
            "retrievalScore": 0.95
          }
        ],
        "laneKinds": {
          "dense-main": "dense"
        },
        "calibration": {
          "version": "contract-calibration-v1",
          "lanes": {
            "dense-main": {
              "minimumScore": 0.5,
              "scoreField": "retrieval"
            }
          }
        }
      },
      "expected": {
        "abstain": true,
        "reason": "identifier_requires_lexical_evidence",
        "qualifiedEvidenceIds": [
          "dense-identifier-candidate"
        ],
        "distinctDocumentCount": 1,
        "calibrationVersion": "contract-calibration-v1"
      }
    },
    {
      "id": "identifier-abstention-allows-calibrated-hybrid-lexical-proof",
      "input": {
