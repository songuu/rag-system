      },
      "expected": {
        "abstain": false,
        "reason": "sufficient_evidence",
        "qualifiedEvidenceIds": [
          "hybrid-identifier-proof"
        ],
        "distinctDocumentCount": 1,
        "calibrationVersion": "contract-calibration-v1"
      }
    },
