    {
      "id": "router-shadow-capability-cannot-change-generation-route",
      "input": {
        "kind": "retrieval-router",
        "query": "错误码 ERR-42 的含义是什么？",
        "hybrid": {
          "mode": "shadow",
          "usable": true
        },
        "orderedContext": {
          "mode": "off",
          "usable": false
        }
      },
      "expected": {
        "capabilities": {
          "hybridActive": false,
          "orderedContextActive": false
        },
        "route": "dense",
        "queryKind": "identifier",
        "reason": "identifier_hybrid_unavailable"
      }
    },
    {
      "id": "router-active-usable-hybrid-can-handle-identifiers",
      "input": {
        "kind": "retrieval-router",
        "query": "错误码 ERR-42 的含义是什么？",
        "hybrid": {
          "mode": "active",
          "usable": true
        },
        "orderedContext": {
          "mode": "off",
          "usable": false
        }
      },
      "expected": {
        "capabilities": {
          "hybridActive": true,
          "orderedContextActive": false
        },
        "route": "hybrid",
        "queryKind": "identifier",
        "reason": "identifier_prefers_lexical"
      }
    },
    {
      "id": "router-active-ordered-context-requires-a-bounded-complete-corpus",
      "input": {
        "kind": "retrieval-router",
        "query": "总结全文并按顺序说明",
        "hybrid": {
          "mode": "off",
          "usable": false
        },
        "orderedContext": {
          "mode": "active",
          "usable": true
        },
        "corpus": {
          "documentCount": 2,
          "characterCount": 2000,
          "complete": true
        }
      },
      "expected": {
        "capabilities": {
          "hybridActive": false,
          "orderedContextActive": true
        },
        "route": "ordered-context",
        "queryKind": "global",
        "reason": "bounded_global_prefers_ordered_context"
      }
    },
    {
      "id": "hybrid-off-does-not-probe-or-participate",
      "input": {
        "kind": "hybrid-rollout",
        "mode": "off",
        "query": "Find ERR-42",
        "capability": {
          "nativeHybridSearch": true,
          "bm25Function": true,
          "schemaCompatible": true,
          "provider": "hermetic-fake"
        },
        "hits": [
          {
            "id": "hybrid-hit-a",
            "score": 0.9,
            "content": "ERR-42 means retry later."
          }
        ]
      },
      "expected": {
        "status": "completed",
        "mode": "off",
        "participatesInGeneration": false,
        "hitIds": [],
        "shadowHitIds": [],
        "stopReason": "disabled",
        "probeCalls": 0,
        "searchCalls": 0
      }
    },
    {
      "id": "hybrid-shadow-records-hits-without-generation",
      "input": {
        "kind": "hybrid-rollout",
        "mode": "shadow",
        "query": "Find ERR-42",
        "capability": {
          "nativeHybridSearch": true,
          "bm25Function": true,
          "schemaCompatible": true,
          "provider": "hermetic-fake"
        },
        "hits": [
          {
            "id": "hybrid-hit-a",
            "score": 0.9,
            "content": "ERR-42 means retry later."
          },
          {
            "id": "hybrid-hit-b",
            "score": 0.7,
            "content": "ERR-42 is an example contract code."
          }
        ]
      },
      "expected": {
        "status": "completed",
        "mode": "shadow",
        "participatesInGeneration": false,
        "hitIds": [],
        "shadowHitIds": [
          "hybrid-hit-a",
          "hybrid-hit-b"
        ],
        "stopReason": "shadow_only",
        "probeCalls": 1,
        "searchCalls": 1
      }
    },
    {
      "id": "hybrid-active-fails-closed-without-native-capability",
      "input": {
        "kind": "hybrid-rollout",
        "mode": "active",
        "query": "Find ERR-42",
        "capability": {
          "nativeHybridSearch": true,
          "bm25Function": false,
          "schemaCompatible": true,
          "provider": "hermetic-fake"
        },
        "hits": []
      },
      "expected": {
        "status": "rejected",
        "code": "HYBRID_CAPABILITY_REQUIRED",
        "probeCalls": 1,
        "searchCalls": 0
      }
    },
    {
      "id": "hybrid-active-uses-native-hits-only-after-capability-gate",
      "input": {
        "kind": "hybrid-rollout",
        "mode": "active",
        "query": "Find ERR-42",
        "capability": {
          "nativeHybridSearch": true,
          "bm25Function": true,
          "schemaCompatible": true,
          "provider": "hermetic-fake"
        },
        "hits": [
          {
            "id": "hybrid-hit-a",
            "score": 0.9,
            "content": "ERR-42 means retry later."
          }
        ]
      },
      "expected": {
        "status": "completed",
        "mode": "active",
        "participatesInGeneration": true,
        "hitIds": [
          "hybrid-hit-a"
        ],
        "shadowHitIds": [],
        "stopReason": "sufficient",
        "probeCalls": 1,
        "searchCalls": 1
      }
    },
    {
      "id": "lane-transform-preserves-evidence-identity-and-provenance",
      "input": {
        "kind": "lane-evidence-transform",
        "evidence": [
          {
            "id": "chunk-a",
            "tenantId": "contract-tenant",
            "corpusId": "contract-corpus",
            "documentId": "document-a",
            "documentVersion": "v1",
            "content": "first source chunk",
            "trustLevel": "reviewed",
            "laneId": "dense-main",
            "retrievalScore": 0.8
          },
          {
            "id": "chunk-b",
            "tenantId": "contract-tenant",
            "corpusId": "contract-corpus",
            "documentId": "document-a",
            "documentVersion": "v1",
            "content": "second source chunk",
            "trustLevel": "reviewed",
            "laneId": "dense-main",
            "retrievalScore": 0.7
          }
        ],
        "orderedEvidenceIds": [
          "chunk-b",
          "chunk-a"
        ],
        "rerankScores": {
          "chunk-a": 0.8,
          "chunk-b": 0.95
        }
      },
      "expected": {
        "evidenceIds": [
          "chunk-b",
          "chunk-a"
        ],
        "documentIds": [
          "document-a",
          "document-a"
        ],
        "laneIds": [
          "dense-main",
          "dense-main"
        ],
        "rerankScores": [
          0.95,
          0.8
        ],
        "laneExecutions": [
          {
            "laneId": "dense-main",
            "status": "completed",
            "evidenceIds": [
              "chunk-a",
              "chunk-b"
            ]
          },
          {
            "laneId": "rerank-main",
            "status": "completed",
            "evidenceIds": [
              "chunk-b",
              "chunk-a"
            ]
          }
        ],
        "stopReason": "sufficient"
      }
    },
