# Copy to .env.container for docker compose, or pass these as runtime secrets in a cloud platform.
# Never commit .env.container with real keys.

# App runtime
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
NEXT_TELEMETRY_DISABLED=1

# Mode A: local migration rehearsal (host Ollama + compose Milvus)
MODEL_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama
REASONING_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=llama3.1
OLLAMA_REASONING_MODEL=deepseek-r1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
MILVUS_PROVIDER=local
MILVUS_LOCAL_ADDRESS=milvus:19530
MILVUS_DEFAULT_DATABASE=default
MILVUS_DEFAULT_COLLECTION=rag_documents
MILVUS_DEFAULT_DIMENSION=768
RAG_PERSISTENCE_BACKEND=local
RAG_VECTOR_BACKEND=milvus

# API boundary (required because NODE_ENV=production)
# Generate a long random token and send it as: Authorization: Bearer <token>
RAG_ACCESS_MODE=single-tenant-token
RAG_SINGLE_TENANT_TOKEN=replace-with-a-long-random-secret
RAG_SINGLE_TENANT_ROLE=owner
SUPABASE_DEFAULT_TENANT_ID=local-production
SUPABASE_DEFAULT_CORPUS_ID=default
RAG_TENANT_ISOLATION_REQUIRED=true
RAG_ALLOWED_LLM_MODELS=llama3.1
RAG_ALLOWED_EMBEDDING_MODELS=nomic-embed-text
RAG_EXTERNAL_URL_ALLOW_HTTP=false

# Mode B: hybrid migration (self-hosted/custom LLM + cloud embedding/vector)
# MODEL_PROVIDER=custom
# CUSTOM_API_KEY=replace-me
# CUSTOM_BASE_URL=https://api.deepseek.com
# CUSTOM_LLM_MODEL=deepseek-chat
# EMBEDDING_PROVIDER=siliconflow
# SILICONFLOW_API_KEY=replace-me
# SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3
# MILVUS_PROVIDER=zilliz
# MILVUS_ZILLIZ_ENDPOINT=in01-xxx.api.gcp-us-west1.zillizcloud.com:443
# MILVUS_ZILLIZ_TOKEN=replace-me
# MILVUS_DEFAULT_DIMENSION=1024

# Mode C: cloud migration (cloud LLM + cloud embedding + Zilliz + Supabase persistence)
# MODEL_PROVIDER=openai
# OPENAI_API_KEY=replace-me
# OPENAI_LLM_MODEL=gpt-4o-mini
# OPENAI_REASONING_MODEL=gpt-4o
# EMBEDDING_PROVIDER=siliconflow
# SILICONFLOW_API_KEY=replace-me
# SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3
# MILVUS_PROVIDER=zilliz
# MILVUS_ZILLIZ_ENDPOINT=in01-xxx.api.gcp-us-west1.zillizcloud.com:443
# MILVUS_ZILLIZ_TOKEN=replace-me
# MILVUS_DEFAULT_DIMENSION=1024
# RAG_PERSISTENCE_BACKEND=supabase
# RAG_VECTOR_BACKEND=zilliz
# RAG_ACCESS_MODE=supabase
# RAG_TENANT_ISOLATION_REQUIRED=true
# RAG_ALLOWED_LLM_MODELS=gpt-4o-mini
# RAG_ALLOWED_EMBEDDING_MODELS=BAAI/bge-m3
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-me
# SUPABASE_SERVICE_ROLE_KEY=replace-me
# SUPABASE_DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
# SUPABASE_DEFAULT_CORPUS_ID=00000000-0000-0000-0000-000000000002
# SUPABASE_STORAGE_RAW_BUCKET=rag-raw-files
# SUPABASE_STORAGE_PARSED_BUCKET=rag-parsed-text

# Optional observability
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=rag-system
# LANGSMITH_API_KEY=replace-me
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Reasoning RAG
REASONING_RAG_COLLECTION=reasoning_rag_documents
REASONING_RAG_UPLOAD_DIR=reasoning-uploads
REASONING_RAG_CHUNK_SIZE=500
REASONING_RAG_CHUNK_OVERLAP=50
REASONING_RAG_TOP_K=50
REASONING_RAG_RERANK_TOP_K=5
REASONING_RAG_SIMILARITY_THRESHOLD=0.3
REASONING_RAG_ENABLE_BM25=true
REASONING_RAG_ENABLE_RERANK=true
REASONING_RAG_MAX_ITERATIONS=3
REASONING_RAG_TEMPERATURE=0.7
